# Copy to .env (for AWS deploy) or .env.local (for local docker-compose) and fill in.
# NEVER commit .env or .env.local — both are gitignored.
# All secrets loaded from environment, never hardcoded in Terraform or K8s manifests.

# ── Local docker-compose mode ──────────────────────────────────────────────
# Required for: docker compose -f docker-compose.local.yml up -d
JWT_SECRET=          # any random string for local dev
GRAFANA_PASSWORD=admin

# LocalStack listens on http://localhost:4566 — no AWS account needed.
# Run ./scripts/local-seed.sh after stack is up to seed secrets into LocalStack.

# AWS
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
AWS_DEPLOY_ROLE_ARN=          # IAM role for GitHub Actions OIDC

# Terraform state backend
TF_BACKEND_BUCKET=            # S3 bucket for tf state
TF_BACKEND_REGION=us-east-1

# Terraform secrets (passed as TF_VAR_* — never in .tfvars files committed to git)
TF_VAR_db_password=
TF_VAR_jwt_secret=
TF_VAR_grafana_admin_password=
TF_VAR_spinnaker_ui_password=

# Anvay webhook (for Alertmanager → Anvay alert ingestion)
ANVAY_WEBHOOK_URL=

# Set in GitHub repository secrets (Settings → Secrets → Actions):
# AWS_DEPLOY_ROLE_ARN
# APP_IRSA_ROLE_ARN
# GRAFANA_ADMIN_PASSWORD
# ANVAY_WEBHOOK_URL
