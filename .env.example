# Copy to .env.local (for local minikube) or .env (for AWS deploy) and fill in.
# NEVER commit .env or .env.local — both are gitignored.
# All secrets loaded from environment, never hardcoded in Terraform or K8s manifests.

# ── Local minikube mode ────────────────────────────────────────────────────
# Required for: source .env.local && ./scripts/local-k8s.sh
JWT_SECRET=local-dev-secret-change-me

# Must match ANVAY_WEBHOOK_TOKEN in apps/gateway/.env
# Alertmanager in minikube fires → http://host.docker.internal:4000/api/events/alert
ANVAY_WEBHOOK_TOKEN=anvay-demo-webhook-token

# ── AWS / EKS production deploy ────────────────────────────────────────────
# Required for: terraform apply + ./scripts/deploy.sh
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
AWS_DEPLOY_ROLE_ARN=          # IAM role for GitHub Actions OIDC

# Terraform state backend
TF_BACKEND_BUCKET=            # S3 bucket for tf state
TF_BACKEND_REGION=us-east-1

# Terraform secrets (passed as TF_VAR_* — never in .tfvars files committed to git)
TF_VAR_db_password=
TF_VAR_jwt_secret=
TF_VAR_grafana_admin_password=
TF_VAR_spinnaker_ui_password=

# Anvay webhook URL (for Alertmanager → Anvay in EKS — the full public URL)
ANVAY_WEBHOOK_URL=

# Set in GitHub repository secrets (Settings → Secrets → Actions):
# AWS_DEPLOY_ROLE_ARN
# APP_IRSA_ROLE_ARN
# GRAFANA_ADMIN_PASSWORD
# ANVAY_WEBHOOK_URL
# ANVAY_GATEWAY_URL
# ANVAY_CONNECTOR_KEY
# ANVAY_TENANT_ID
