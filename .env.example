# Copy to .env and fill in — NEVER commit .env
# All secrets loaded from environment, never hardcoded in Terraform or K8s manifests

# AWS
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
AWS_DEPLOY_ROLE_ARN=          # IAM role for GitHub Actions OIDC

# Terraform state backend
TF_BACKEND_BUCKET=            # S3 bucket for tf state
TF_BACKEND_REGION=us-east-1

# Terraform secrets (passed as TF_VAR_* — never in .tfvars files committed to git)
TF_VAR_db_password=
TF_VAR_jwt_secret=
TF_VAR_grafana_admin_password=
TF_VAR_spinnaker_ui_password=

# Anvay webhook (for Alertmanager → Anvay alert ingestion)
ANVAY_WEBHOOK_URL=

# Set in GitHub repository secrets (Settings → Secrets → Actions):
# AWS_DEPLOY_ROLE_ARN
# APP_IRSA_ROLE_ARN
# GRAFANA_ADMIN_PASSWORD
# ANVAY_WEBHOOK_URL
